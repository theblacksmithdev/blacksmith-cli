/**
 * Blacksmith Router
 *
 * Converts a simple route config object into a full React Router setup
 * with lazy loading, auth guards, error boundaries, and prefetching.
 *
 * Generated by Blacksmith. You own this file — customize as needed.
 */

import { createBrowserRouter, type RouteObject } from 'react-router-dom'
import type { BlacksmithRoutes, BlacksmithRoute } from './types'
import { AuthGuard } from './auth-guard'
import { RouteErrorBoundary } from './error-boundary'
import { queryClient } from '@/api/query-client'

/**
 * Resolve a page string to a lazy import function.
 *
 * Convention:
 * - 'home' → import('@/pages/home.tsx')
 * - 'posts/posts-page' → import('@/features/posts/pages/posts-page.tsx')
 */
function resolvePageImport(pagePath: string) {
  const parts = pagePath.split('/')

  if (parts.length === 1) {
    // Simple page: 'home' → @/pages/home.tsx
    const modules = import.meta.glob('@/pages/*.tsx')
    const key = `/src/pages/${parts[0]}.tsx`
    return modules[key] as () => Promise<any>
  }

  // Feature page: 'posts/posts-page' → @/features/posts/pages/posts-page.tsx
  const modules = import.meta.glob('@/features/*/pages/*.tsx')
  const feature = parts[0]
  const page = parts.slice(1).join('/')
  const key = `/src/features/${feature}/pages/${page}.tsx`
  return modules[key] as () => Promise<any>
}

/**
 * Build a React Router route object from a Blacksmith route definition
 */
function buildRoute(route: BlacksmithRoute): RouteObject {
  const routeObj: RouteObject = {}

  if (route.path !== undefined) routeObj.path = route.path
  if (route.index) routeObj.index = true

  if (route.page) {
    const importFn = resolvePageImport(route.page)

    if (!importFn) {
      console.warn(`[Blacksmith Router] Page not found: "${route.page}"`)
      routeObj.lazy = async () => ({
        Component: () => <div>Page not found: {route.page}</div>,
      })
    } else {
      routeObj.lazy = async () => {
        const mod = await importFn()
        return {
          Component: mod.default,
          loader: mod.prefetch
            ? () => mod.prefetch(queryClient)
            : undefined,
        }
      }
    }
  }

  // Auth guard wrapper
  if (route.auth) {
    const originalLazy = routeObj.lazy
    routeObj.lazy = async () => {
      const result = originalLazy ? await originalLazy() : {}
      const OriginalComponent = result.Component

      return {
        ...result,
        Component: () => (
          <AuthGuard roles={route.roles}>
            {OriginalComponent ? <OriginalComponent /> : null}
          </AuthGuard>
        ),
      }
    }
  }

  // Recurse for children
  if (route.children) {
    routeObj.children = route.children.map(buildRoute)
  }

  return routeObj
}

/**
 * Create a React Router browser router from a Blacksmith route configuration.
 */
export function createBlacksmithRouter(config: BlacksmithRoutes) {
  return createBrowserRouter([
    // Auth routes — wrapped in AuthLayout
    {
      lazy: async () => {
        const { AuthLayoutWrapper } = await import('./layouts/auth-layout')
        return { Component: AuthLayoutWrapper }
      },
      errorElement: <RouteErrorBoundary />,
      children: [
        {
          path: config.auth.login,
          lazy: async () => {
            const mod = await import('@/features/auth/pages/login-page')
            return { Component: mod.default }
          },
        },
        {
          path: config.auth.register,
          lazy: async () => {
            const mod = await import('@/features/auth/pages/register-page')
            return { Component: mod.default }
          },
        },
        {
          path: config.auth.forgotPassword,
          lazy: async () => {
            const mod = await import('@/features/auth/pages/forgot-password-page')
            return { Component: mod.default }
          },
        },
        {
          path: config.auth.resetPassword,
          lazy: async () => {
            const mod = await import('@/features/auth/pages/reset-password-page')
            return { Component: mod.default }
          },
        },
      ],
    },

    // App routes — wrapped in MainLayout
    {
      lazy: async () => {
        const { MainLayout } = await import('./layouts/main-layout')
        return { Component: MainLayout }
      },
      errorElement: <RouteErrorBoundary />,
      children: config.routes.map(buildRoute),
    },

    // Catch-all 404
    {
      path: '*',
      lazy: async () => {
        const mod = await import('@/shared/components/not-found-page')
        return { Component: mod.default }
      },
    },
  ])
}
