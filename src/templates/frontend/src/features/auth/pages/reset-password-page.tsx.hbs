import { ResetPasswordForm } from '@blacksmith-ui/auth'
import { useNavigate, useParams } from 'react-router-dom'
import { useAuth } from '../hooks/use-auth'
import { useState } from 'react'
import routeConfig from '@/blacksmith.routes'

export default function ResetPasswordPage() {
  const navigate = useNavigate()
  const { token } = useParams<{ token: string }>()
  const { confirmPasswordReset, error } = useAuth()
  const [loading, setLoading] = useState(false)

  const handleSubmit = async (data: { password: string; code: string }) => {
    setLoading(true)
    try {
      const result = await confirmPasswordReset(data.code, data.password)
      if (result.success) {
        navigate(routeConfig.auth.login, { replace: true })
      }
    } finally {
      setLoading(false)
    }
  }

  return (
    <ResetPasswordForm
      onSubmit={handleSubmit}
      code={token || ''}
      onLoginClick={() => navigate(routeConfig.auth.login)}
      error={error}
      loading={loading}
    />
  )
}
