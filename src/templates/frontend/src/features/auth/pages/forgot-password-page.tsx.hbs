import { ForgotPasswordForm } from '@blacksmith-ui/auth'
import { useNavigate } from 'react-router-dom'
import { useAuth } from '../hooks/use-auth'
import { useState } from 'react'
import routeConfig from '@/blacksmith.routes'

export default function ForgotPasswordPage() {
  const navigate = useNavigate()
  const { sendPasswordResetEmail, error } = useAuth()
  const [loading, setLoading] = useState(false)

  const handleSubmit = async (data: { email: string }) => {
    setLoading(true)
    try {
      await sendPasswordResetEmail(data.email)
      // Show success regardless (prevents email enumeration)
    } finally {
      setLoading(false)
    }
  }

  return (
    <ForgotPasswordForm
      onSubmit={handleSubmit}
      onLoginClick={() => navigate(routeConfig.auth.login)}
      error={error}
      loading={loading}
    />
  )
}
