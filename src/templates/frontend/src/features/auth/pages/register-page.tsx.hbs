import { RegisterForm } from '@blacksmith-ui/auth'
import { useNavigate } from 'react-router-dom'
import { useAuth } from '../hooks/use-auth'
import routeConfig from '@/blacksmith.routes'

export default function RegisterPage() {
  const navigate = useNavigate()
  const { register, error, isLoading } = useAuth()

  const handleSubmit = async (data: {
    email: string
    password: string
    displayName: string
  }) => {
    const result = await register(data.email, data.password, data.displayName)
    if (result.success) {
      navigate(routeConfig.auth.afterLogin, { replace: true })
    }
  }

  return (
    <RegisterForm
      onSubmit={handleSubmit}
      onLoginClick={() => navigate(routeConfig.auth.login)}
      error={error}
      loading={isLoading}
    />
  )
}
