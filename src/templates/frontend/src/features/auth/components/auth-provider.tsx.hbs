const adapter = createBlacksmithAuthAdapter()

interface Props {
  children: ReactNode
}

export function AuthProvider({ children }: Props) {
  return (
    <BlacksmithAuthProvider
      config=\{{
        adapter,
        // Enable social providers by adding them here:
        // socialProviders: ['google', 'github'],
      }}
    >
      {children}
    </BlacksmithAuthProvider>
  )
}
