import { AuthProvider as FlatUIAuthProvider } from '@flatui/auth-ui'
import { createForgeAuthAdapter } from '../adapter'
import type { ReactNode } from 'react'

const adapter = createForgeAuthAdapter()

interface Props {
  children: ReactNode
}

export function AuthProvider({ children }: Props) {
  return (
    <FlatUIAuthProvider
      config={{
        adapter,
        // Enable social providers by adding them here:
        // socialProviders: ['google', 'github'],
      }}
    >
      {children}
    </FlatUIAuthProvider>
  )
}
